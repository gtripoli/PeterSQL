          "NULLS LAST"
        ]
      }
    },
    {
      "case_id": "ORDER_002",
      "title": "ORDER BY with prefix filters columns/functions/keywords",
      "sql": "SELECT * FROM users ORDER BY c|",
      "dialect": "generic",
      "current_table": null,
      "schema_variant": "small",
      "expected": {
        "mode": "PREFIX",
        "context": "ORDER_BY_CLAUSE",
        "prefix": "c",
        "suggestions": [
          "users.created_at",
          "CONCAT",
          "COUNT",
          "CURRENT_DATE",
          "CURRENT_TIME",
          "CURRENT_TIMESTAMP"
        ],
        "xfail": true
      }
    },
    {
