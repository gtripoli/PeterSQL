        "mode": "PREFIX",
        "context": "JOIN_ON",
        "prefix": "i",
        "alias_exact_match": "i",
        "comment": "With prefix matching alias 'i', suggest i.* columns. No left-column filtering with prefix.",
        "suggestions": [
          "i.id",
