    {
      "case_id": "MQ_EXTRACT_004",
      "title": "Multi-query - cursor on separator resolves as prefix in next statement",
      "sql": "SELECT * FROM users;|",
      "dialect": "generic",
      "current_table": null,
      "schema_variant": "small",
      "expected": {
        "mode": "PREFIX",
        "context": "FROM_CLAUSE",
        "prefix": "users",
        "comment": "Current parser behavior resolves token before separator as FROM prefix.",
        "suggestions": [
          "users"
        ]
      }
    },
    {
      "case_id": "MQ_EXTRACT_005",
      "title": "Multi-query - empty statement between separators",
      "sql": "SELECT * FROM users; ; SELECT |",
      "dialect": "generic",
      "current_table": null,
      "schema_variant": "small",
      "expected": {
        "mode": "CONTEXT",
