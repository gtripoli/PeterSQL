          "LEFT JOIN",
          "RIGHT JOIN",
          "CROSS JOIN",
          "AS",
          "WHERE",
          "GROUP BY",
          "ORDER BY",
          "LIMIT"
        ]
      }
    },
    {
      "case_id": "FROM_005",
      "title": "FROM includes CTE names defined in same statement",
