      "dialect": "generic",
      "current_table": null,
      "schema_variant": "small",
      "expected": {
        "mode": "CONTEXT",
        "context": "FROM_CLAUSE",
        "prefix": null,
        "suggestions": [
          "customers",
          "orders",
          "payments",
          "products",
          "users"
        ]
      }
    },
    {
      "case_id": "FROM_006",
      "title": "CTE not visible across statements",
      "sql": "WITH a AS (SELECT 1) SELECT * FROM a; SELECT * FROM |",
      "dialect": "generic",
      "current_table": null,
      "schema_variant": "small",
      "expected": {
        "mode": "CONTEXT",
        "context": "FROM_CLAUSE",
        "prefix": null,
        "suggestions": [
          "customers",
          "orders",
          "payments",
          "products",
          "users"
        ]
      }
    },
    {
      "case_id": "FROM_007",
      "title": "After AS with space, no suggestions (user typing alias)",
      "sql": "SELECT * FROM users AS |",
      "dialect": "generic",
      "current_table": null,
      "schema_variant": "small",
      "expected": {
        "mode": "CONTEXT",
        "context": "FROM_CLAUSE",
        "prefix": null,
        "comment": "After AS keyword, user is typing an alias name, so no suggestions should be shown",
        "suggestions": []
      }
    },
    {
      "case_id": "FROM_008",
      "title": "After AS with partial alias, no suggestions",
      "sql": "SELECT * FROM users AS u|",
      "dialect": "generic",
      "current_table": null,
      "schema_variant": "small",
      "expected": {
        "mode": "PREFIX",
        "context": "FROM_CLAUSE",
        "prefix": "u",
