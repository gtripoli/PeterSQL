      "case_id": "HINT_001",
      "title": "SELECT_LIST scoped prefix includes scope matches and DB-wide expansion",
      "sql": "SELECT c| FROM orders",
      "dialect": "generic",
      "current_table": null,
      "schema_variant": "small",
      "expected": {
        "mode": "PREFIX",
        "context": "SELECT_LIST",
        "prefix": "c",
        "comment": "Current behavior includes DB-wide expansion and scope column matches for prefix 'c'.",
        "suggestions": [
          "customers.id",
          "customers.name",
          "customers.email",
          "carts.id",
          "carts.customer_id",
          "carts.created_at",
          "carts.cart_total",
          "orders.created_at",
          "users.created_at",
          "payments.created_at",
          "COALESCE",
          "CONCAT",
          "COUNT",
          "CURRENT_DATE",
          "CURRENT_TIME",
          "CURRENT_TIMESTAMP",
          "CREATE",
          "CROSS JOIN"
        ]
      }
    },
    {
      "case_id": "HINT_002",
      "title": "KILLER: Out-of-scope hint when prefix matches NO scope columns, only DB table",
      "sql": "SELECT u| FROM products",
      "dialect": "generic",
      "current_table": null,
      "schema_variant": "small",
      "expected": {
        "mode": "PREFIX",
        "context": "SELECT_LIST",
        "prefix": "u",
        "comment": "Scope=[products]. Prefix 'u' matches NO scope columns (products has: id,name,price,unit_price,stock). Matches DB table 'users'. HINT MODE: functions first, then table hint, NO DB-wide columns.",
        "suggestions": [
          "users.id",
          "users.name",
          "users.email",
          "users.status",
          "users.created_at",
          "user_sessions.id",
          "user_sessions.user_id",
          "user_sessions.session_token",
          "user_sessions.expires_at",
          "products.unit_price",
          "orders.user_id",
          "UNIX_TIMESTAMP",
          "UPPER",
          "UUID",
          "UPDATE",
          "USING"
        ]
      }
    },
    {
