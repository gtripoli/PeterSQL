      "case_id": "HINT_001",
      "title": "Out-of-scope table hint when prefix matches only DB-wide tables",
      "sql": "SELECT c| FROM orders",
      "dialect": "generic",
      "current_table": null,
      "schema_variant": "small",
      "expected": {
        "mode": "PREFIX",
